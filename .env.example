# ============================================================
# AI Compliance Suite — Environment Variables Template
# ============================================================
#
# Vor dem Start: Kopiere zu .env und passe Werte an
#   cp .env.example .env
#

# ---- AUTH (Pflicht) ----
# JWT-Secret muss mindestens 32 Zeichen sein. Generieren mit:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# Token-Lebensdauer in Stunden (default: 24)
JWT_EXPIRES_HOURS=24

# ---- PASSKEY / WEBAUTHN / FIDO2 (Sprint ε) ----
# WICHTIG: RP-ID und Origin MÜSSEN zur ausliefernden Domain passen, sonst
# verweigert der Browser die Passkey-Nutzung stillschweigend.
#   - RP_ID  = registrierbare Domain OHNE Schema/Port (z.B. 'localhost' oder 'aics.example.com')
#   - ORIGIN = vollständige(r) Origin(s) MIT Schema+Port (komma-separiert erlaubt)
# Hinter Nginx (TLS-Termination): ORIGIN = öffentliche https-Adresse, NICHT die interne.
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=AI Compliance Suite
WEBAUTHN_RP_ORIGIN=https://localhost:8443

# CORS — komma-separierte Liste erlaubter Origins
# Production: nur die echte Domain eintragen!
CORS_ORIGINS=https://localhost,https://localhost:443

# ---- USER-MANAGEMENT ----
# Legt Demo-Users an (admin@example.com / admin-password). NUR FÜR DEV!
ENABLE_DEMO_USERS=false

# ---- HTTPS ----
# Wenn Nginx als Reverse-Proxy läuft: false (Nginx terminiert)
# Standalone Backend: true (Auto-Self-Signed-Cert wird generiert)
HTTPS_ENABLED=false

# ---- GUNICORN ----
GUNICORN_WORKERS=4

# ---- LDAP/AD (optional, Issue #270) ----
LDAP_ENABLED=false
LDAP_SERVER=
LDAP_BASE_DN=
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=
# JSON-Mapping LDAP-Group → Application-Role
LDAP_GROUP_MAPPING={}

# ---- AI/LLM (optional) ----
# Cloud-Provider API-Key (OpenAI, Anthropic, ...)
AI_CLOUD_API_KEY=

# ---- VCS Integration ----
# GitHub: gh-CLI muss separat authentifiziert sein
# GitLab Token (für Issue-Creation/Sync)
GITLAB_TOKEN=
